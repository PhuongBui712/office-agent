# DA-Agent backend runtime env. Copy to `.env` and fill in your token:
#   cp .env.docker.example .env
#
# These are passed to the backend container and, in turn, to the `claude` CLI
# subprocess the Agent SDK spawns. Do NOT commit the filled-in .env.

# --- Anthropic-compatible endpoint (Databricks serving endpoint) ---
ANTHROPIC_BASE_URL=https://<your-workspace>.azuredatabricks.net/serving-endpoints/anthropic
ANTHROPIC_AUTH_TOKEN=

# Model ids served by your endpoint.
ANTHROPIC_MODEL=databricks-claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=databricks-claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=databricks-claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=databricks-claude-sonnet-4-6

# Databricks requires this header to route to the coding-agent mode.
ANTHROPIC_CUSTOM_HEADERS=x-databricks-use-coding-agent-mode: true

# --- App settings ---
# Model the agent loop uses (see src/da_agent/config.py).
DA_AGENT_MODEL=databricks-claude-sonnet-4-6

# Only needed when the FE is served from a non-default origin (see README).
# DA_AGENT_CORS_ORIGINS=http://your-host:3000

# Only needed when the FE must reach the backend at a non-default URL (baked
# into the FE at build time). Used by docker-compose to build the FE image.
# VITE_API_BASE_URL=http://your-host:8765
